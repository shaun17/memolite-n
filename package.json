{
  "name": "memolite-n",
  "version": "0.0.0",
  "description": "Node/TypeScript rewrite of memolite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "scripts",
    "assets/openclaw-plugin"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "memolite": "./bin/memolite.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run test && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "better-sqlite3": "^12.4.1",
    "commander": "^14.0.1",
    "fastify": "^5.6.0",
    "kuzu": "^0.11.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
